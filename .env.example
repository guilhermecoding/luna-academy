# Nome da corporação
NEXT_PUBLIC_NAME_CORPORATION=

# URL do logo da corporação
NEXT_PUBLIC_LOGO_CORPORATION=

# URL do banco de dados
DATABASE_URL=""

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
BETTER_AUTH_TRUSTED_ORIGINS=

# Seed — administrador inicial (pnpm seed)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_CPF=
ADMIN_PHONE=
ADMIN_BIRTH_DATE=
ADMIN_BIO=
ADMIN_LUNA_ID=
# ADMIN_LUNA_ID deve estar no formato ano + sequencial com 5 dígitos (ex: 202600001)

# Resend
RESEND_API_KEY=
EMAIL_FROM="Luna Academy <subdomain@domain.com>"
NEXT_PUBLIC_APP_URL=https://subdomain.domain.com

# Origens extras no dev (allowedDevOrigins): hosts separados por vírgula, ex. 192.168.0.10,192.168.0.10:3000 ou http://192.168.0.10:3000
# Preferível sem NEXT_PUBLIC (não é variável de cliente). next.config carrega .env antes de ler.
ALLOWED_DEV_ORIGINS=
NEXT_PUBLIC_ALLOWED_DEV_ORIGINS=

# Modo de build - production ou development ou undefined
NEXT_PUBLIC_BUILD_MODE=

# Versão exibida na UI (opcional; padrão: version do package.json)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Fuso horário da aplicação (IANA). Usado na exibição de horários de chamada e comparações de data.
# Valores inválidos são ignorados; fallback: America/Sao_Paulo
NEXT_PUBLIC_APP_TIMEZONE=America/Sao_Paulo